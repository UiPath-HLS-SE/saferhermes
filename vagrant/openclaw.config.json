{
  // OpenClaw Hardened Configuration

  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "trustedProxies": ["127.0.0.1"],
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}",
      "allowTailscale": false
    },
    "controlUi": {
      "allowInsecureAuth": false,
      "dangerouslyDisableDeviceAuth": false
    }
  },
  "logging": {
    "level": "trace",
    "redactSensitive": "tools"
  },
  "channels": {
    "whatsapp": {
      "dmPolicy": "disabled"
    },
    "slack": {
      "enabled": false
    },
    "telegram": {
      "enabled": false
    },
    "discord": {
      "enabled": false
    },
    "signal": {
      "enabled": false
    },
    "imessage": {
      "enabled": false
    },
    "googlechat": {
      "enabled": false
    }
  },
  "tools": {
    "allow": ["group:runtime", "group:fs", "group:web", "group:ui"],
    "deny": [],
    "sandbox": {
      "tools": {
        "allow": ["group:runtime", "group:fs", "group:web", "group:ui"],
        "deny": []
      }
    },
    "elevated": {
      "enabled": false
    },
    "agentToAgent": {
      "enabled": false
    },
    "web": {
      "fetch": {
        "enabled": true
      },
      "search": {
        "enabled": true
      }
    },
    "subagents": {
      "tools": {
        "allow": ["group:runtime", "group:fs", "group:web", "group:ui"],
        "deny": []
      }
    }
  },
  "plugins": {
    "enabled": false
  },
  "browser": {
    "enabled": true,
    "evaluateEnabled": false
  },
  "agents": {
    "defaults": {
      "workspace": "${OPENCLAW_HOME}/.openclaw/workspace",
      "models": {
        "openrouter/anthropic/claude-sonnet-4.5": { "alias": "sonnet4.5" },
        "openrouter/anthropic/claude-opus-4.6": { "alias": "opus4.6" },
        "openrouter/openai/gpt-5.2": { "alias": "gpt5.2" },
        "openrouter/openai/gpt-5.2-pro": { "alias": "gpt5.2-pro" }
      },
      "model": {
        "primary": "sonnet4.5",
        "fallbacks": ["gpt5.2", "gpt5.2-pro", "opus4.6"]
      },
      "sandbox": {
        "mode": "all",
        "scope": "session",
        "workspaceAccess": "rw",
        "docker": {
          "image": "openclaw-sandbox:bookworm-slim",
          "containerPrefix": "openclaw-sbx-",
          "workdir": "/workspace",
          "tmpfs": ["/tmp", "/var/tmp", "/run"],
          "user": "1000:1000",
          "network": "bridge",
          "env": { "LANG": "C.UTF-8" },
          "memory": "0.5g",
          "memorySwap": "1g",
          "cpus": 1,
          "dns": ["1.1.1.1", "8.8.8.8"]
        },
        "browser": {
          "enabled": true,
          "image": "openclaw-sandbox-browser:bookworm-slim",
          "cdpPort": 9222,
          "vncPort": 5900,
          "noVncPort": 6080,
          "headless": false,
          "enableNoVnc": true,
          "allowHostControl": false,
          "autoStart": false,
          "autoStartTimeoutMs": 12000
        },
        "prune": {
          "idleHours": 24,
          "maxAgeDays": 7
        }
      }
    }
  }
}
